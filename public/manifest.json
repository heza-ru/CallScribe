{
  "manifest_version": 3,
  "name": "CallScribe",
  "version": "1.0.0",
  "description": "Extract Mindtickle transcripts and generate AI-powered tickets in JIRA and Productboard",
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Open CallScribe"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://*.mindtickle.com/*"],
      "js": ["content/queryInterceptor.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://*.mindtickle.com/*"],
      "js": ["content/detectMindtickle.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "downloads",
    "sidePanel"
  ],
  "host_permissions": [
    "https://*.mindtickle.com/*",
    "https://api.anthropic.com/*",
    "https://*.atlassian.net/*",
    "https://api.productboard.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["content/transcriptFetcher.js", "content/queryInterceptor.js"],
      "matches": ["https://*.mindtickle.com/*"]
    }
  ]
}
